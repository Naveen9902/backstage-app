// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WORKER
  MANAGER
  ADMIN
  USER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  PAID
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  password             String
  name                 String
  mobile               String?
  avatarUrl            String?
  role                 Role     @default(WORKER)
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  resetOtp             String?
  resetOtpExpiry       DateTime?
  dateOfBirth          DateTime?
  emergencyContact     String?
  isPhoneVerified      Boolean  @default(false)
  twoFactorSecret      String?
  isTwoFactorEnabled   Boolean  @default(false)
  pushSubscription     String?

  workerProfile    WorkerProfile?
  managerProfile   ManagerProfile?
  events           Event[] // For Managers
  sentMessages     EventChatMessage[] // Messages sent by this user
  reviewsGiven     Review[]           @relation("ReviewsGiven")
  reviewsReceived  Review[]           @relation("ReviewsReceived")
  disputesReported Dispute[]          @relation("DisputesReported")
  disputesTargeted Dispute[]          @relation("DisputesTargeted")
  notifications    Notification[]
  fanEvents        Event[]            @relation("EventFans")
  likedMessages    MessageLike[]
  runnerTasks      RunnerDispatch[]   @relation("RunnerTasks")
}

model ManagerProfile {
  id               String  @id @default(uuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          String?
  bio              String?
  subscriptionTier String  @default("FREE") // FREE | PRO | ENTERPRISE
  stripeCustomerId String? // To save payment methods
  rating           Float   @default(0.0)

  @@index([userId])
}

model WorkerProfile {
  id                 String  @id @default(uuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills             String
  experience         String
  isVerified         Boolean @default(false)
  verificationStatus String  @default("PENDING") // PENDING | APPROVED | REJECTED
  rating             Float   @default(0.0)

  // New extended profile fields
  categories        String[] @default([])
  govtIdUrl         String?
  liveSelfieUrl     String?
  proofOfExperienceType String?
  proofOfExperienceUrl  String?
  socialMediaUrl    String?
  referenceEvent    String?
  referenceContact  String?
  tier              String?
  requestedTier     String?
  specialization    String?
  pastWork          String?
  rates             String?
  portfolioLinks    String?
  isRunnerAvailable Boolean @default(false)
  latitude          Float?
  longitude         Float?

  applications Application[]
  stripeAccountId     String?  // Stripe Connect Account ID for payouts
  stripeAccountStatus String   @default("PENDING") // PENDING, ACTIVE, RESTRICTED
  stripeIdentitySessionId String? // Stripe Identity Verification Session ID

  @@index([userId])
}

model Event {
  id               String             @id @default(uuid())
  managerId        String
  manager          User               @relation(fields: [managerId], references: [id], onDelete: Cascade)
  title            String
  description      String
  date             DateTime
  startTime        String? // e.g. "14:30" (24-hour format)
  status           String             @default("UPCOMING") // UPCOMING | ONGOING | COMPLETED
  location         String
  createdAt        DateTime           @default(now())
  
  // Attendee / Ticketing fields
  attendeeCategory String?
  duration         String?
  language         String?
  tags             String?
  coverImageUrl    String?
  videoUrl         String?
  artistAvatarUrl  String?
  latitude         Float?
  longitude        Float?

  staffingRequests StaffingRequest[]
  runnerDispatches RunnerDispatch[]
  messages         EventChatMessage[]
  reviews          Review[]
  disputes         Dispute[]
  bands            String?
  fans             User[]             @relation("EventFans")

  @@index([managerId])
}

model StaffingRequest {
  id           String        @id @default(uuid())
  eventId      String
  event        Event         @relation(fields: [eventId], references: [id])
  roleName     String
  quantity     Int
  payRate      Float
  tier         String?
  applications Application[]

  @@index([eventId])
}

model Application {
  id                String            @id @default(uuid())
  workerProfileId   String
  workerProfile     WorkerProfile     @relation(fields: [workerProfileId], references: [id])
  staffingRequestId String
  staffingRequest   StaffingRequest   @relation(fields: [staffingRequestId], references: [id])
  status            ApplicationStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  checkInTime       DateTime?
  checkOutTime      DateTime?
  payments          PaymentTransaction[]

  @@index([workerProfileId])
  @@index([staffingRequestId])
}

model RunnerDispatch {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  managerId String
  task      String
  urgency   String
  status    String   @default("Pending")
  runnerId  String?
  runner    User?    @relation("RunnerTasks", fields: [runnerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([managerId])
  @@index([runnerId])
}

model EventChatMessage {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text      String
  imageUrl  String?
  channel   String   @default("announcements")
  createdAt DateTime @default(now())
  
  parentId  String?
  parent    EventChatMessage?  @relation("MessageReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   EventChatMessage[] @relation("MessageReplies")
  likes     MessageLike[]

  @@index([eventId])
  @@index([senderId])
  @@index([parentId])
}

model MessageLike {
  id        String   @id @default(uuid())
  messageId String
  message   EventChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model Review {
  id         String   @id @default(uuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId String
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([eventId, reviewerId, revieweeId]) // Prevent duplicate reviews for same pair in same event
  @@index([eventId])
  @@index([reviewerId])
  @@index([revieweeId])
}

model Dispute {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reporterId  String
  reporter    User     @relation("DisputesReported", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId    String
  target      User     @relation("DisputesTargeted", fields: [targetId], references: [id], onDelete: Cascade)
  reason      String
  description String
  status      String   @default("OPEN") // OPEN | RESOLVED
  resolution  String?
  createdAt   DateTime @default(now())

  @@index([eventId])
  @@index([reporterId])
  @@index([targetId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PaymentTransaction {
  id                    String   @id @default(uuid())
  applicationId         String
  application           Application @relation(fields: [applicationId], references: [id])
  managerId             String
  workerId              String
  amountTotal           Float
  platformFee           Float
  workerPayout          Float
  stripePaymentIntentId String?  @unique
  status                String   @default("PENDING") // PENDING, HELD, PAID_OUT, REFUNDED
  createdAt             DateTime @default(now())

  @@index([applicationId])
  @@index([managerId])
  @@index([workerId])
}

